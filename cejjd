                        'c) 3 paragraphes', 'd) 1 paragraphe'
                    ] },
                { q: '3- D’après le texte, le chien a une vue :', type: 'radio', options: [
                        'a) moins développée que celle de l’homme', 'b) plus développée que celle de l’homme',
                        'c) très très développée'
                    ] },
                { q: '4- Le chien est :', type: 'radio', options: ['a) ovipare', 'b) granivore',
                        'c) un mammifère', 'd) un amphibien'
                    ] },
                { q: '5- L’ouïe du chien lui permet de (d’) :', type: 'radio', options: ['a) entendre des sons',
                        'b) voir très loin', 'c) couper des os', 'd) chasser d’autres animaux'
                    ] },
                { q: '6- Souligne la phrase à la forme pronominale.', type: 'text', placeholder: 'Votre réponse ...' },
                { q: '7- Coche la lettre de la phrase qui a le pronom démonstratif.', type: 'text',
                    placeholder: 'Réponse ...' },
                { q: '8- Entoure les pronoms possessifs.', type: 'text', placeholder: 'Réponse ...' },
                { q: '9- Mets les verbes entre parenthèses aux temps indiqués.', type: 'text',
                    placeholder: 'Votre réponse ...' },
                { q: '10- Entoure les mots de la même famille que « voir ».', type: 'text',
                    placeholder: 'Mots ...' },
            ]
        }, {
            id: 'kominkasyon-kreylò',
            titre: 'Kominkasyon kreylò',
            emoji: '🇭🇹',
            qcount: '10 questions',
            questions: [
                { q: '1- De non moun ki site nan tèks la se :', type: 'radio', options: ['a) David ak Jinèt',
                        'b) Fabiola ak Aksidan', 'c) David ak Balanswa'
                    ] },
                { q: '2- Daprè tèks la, aksidan an te pase :', type: 'radio', options: ['a) aswè',
                        'b) grammante', 'c) apremidi'
                    ] },
                { q: '3- Aksidan an te fèt :', type: 'radio', options: ['a) nan lari a', 'b) sou plasdam nan',
                        'c) bò lannè a'
                    ] },
                { q: '4- Lè aksidan an te fèt :', type: 'radio', options: [
                        'a) tout timoun yo te kouri vin leve David', 'b) David te al leve timoun ki te frape a',
                        'c) Fabiola te mennen timoun nan loptal', 'd) Kèk lòt timoun te mennen l lakay li'
                    ] },
                { q: '5- Konplete ak mo ki nan tèks la.', type: 'text', placeholder: 'a) ... b) ... c) ...' },
                { q: '6- Pase yon trè anba prepozisyon ki nan fraz sa yo.', type: 'text',
                    placeholder: 'Votre réponse ...' },
                { q: '7- Mete fòm predika ki nan fraz sa yo nan parantèz yo.', type: 'text',
                    placeholder: 'Réponse ...' },
                { q: '8- Mete fraz sa yo nan diskou dirèk.', type: 'text', placeholder: 'Votre réponse ...' },
                { q: '9- Fè de fraz, youn ak : a) konplèman dobè dirèk. b) konplèman sikonstansyèl tan.',
                    type: 'text', placeholder: 'Vos phrases ...' },
                { q: '10- Souliye fraz ki endike sibòdone koz la.', type: 'text', placeholder: 'Réponse ...' },
            ]
        }];

        // ============================================================
        // 2. ÉTAT DE L'APPLICATION
        // ============================================================
        let currentUser = null;
        let currentExamId = null;
        let timerInterval = null;
        let timeLeft = 3600; // 60 minutes en secondes
        let examStarted = false;

        // Éléments DOM
        const loginOverlay = document.getElementById('loginOverlay');
        const mainContainer = document.getElementById('mainContainer');
        const loginNom = document.getElementById('loginNom');
        const loginPrenom = document.getElementById('loginPrenom');
        const btnLogin = document.getElementById('btnLogin');
        const btnGoogle = document.getElementById('btnGoogle');
        const userDisplay = document.getElementById('userDisplay');
        const grilleMatieres = document.getElementById('grilleMatieres');
        const examenView = document.getElementById('examenView');
        const examenTitre = document.getElementById('examenTitre');
        const examenBody = document.getElementById('examenBody');
        const timerDisplay = document.getElementById('timerDisplay');
        const btnBack = document.getElementById('btnBack');
        const btnSubmit = document.getElementById('btnSubmit');
        const toast = document.getElementById('toast');

        // ============================================================
        // 3. FONCTIONS UTILITAIRES
        // ============================================================
        function showToast(msg) {
            toast.textContent = msg;
            toast.classList.add('show');
            clearTimeout(toast._hide);
            toast._hide = setTimeout(() => toast.classList.remove('show'), 4000);
        }

        function formatTime(sec) {
            const m = String(Math.floor(sec / 60)).padStart(2, '0');
            const s = String(sec % 60).padStart(2, '0');
            return `${m}:${s}`;
        }

        // ============================================================
        // 4. LOGIN
        // ============================================================
        function handleLogin() {
            const nom = loginNom.value.trim();
            const prenom = loginPrenom.value.trim();
            if (!nom || !prenom) {
                showToast('⚠️ Veuillez entrer votre nom et prénom.');
                return;
            }
            currentUser = { nom, prenom };
            userDisplay.textContent = `${prenom} ${nom}`;
            loginOverlay.classList.add('hidden');
            mainContainer.style.display = 'block';
            renderGrille();
            showToast(`👋 Bienvenue ${prenom} ${nom} !`);
        }

        btnLogin.addEventListener('click', handleLogin);
        // Appuyer sur Entrée dans les champs
        [loginNom, loginPrenom].forEach(inp => inp.addEventListener('keydown', e => { if (e.key === 'Enter')
        handleLogin(); }));

        // Bouton Google (simulation)
        btnGoogle.addEventListener('click', () => {
            showToast('🔐 Connexion Google sera disponible prochainement.');
        });

        // ============================================================
        // 5. GRILLE DES MATIÈRES
        // ============================================================
        function renderGrille() {
            grilleMatieres.innerHTML = '';
            examensData.forEach(exam => {
                const card = document.createElement('div');
                card.className = 'carte';
                card.dataset.id = exam.id;
                card.innerHTML = `
                    <div class="emoji">${exam.emoji}</div>
                    <h3>${exam.titre}</h3>
                    <div class="qcount">${exam.qcount}</div>
                `;
                card.addEventListener('click', () => openExamen(exam.id));
                grilleMatieres.appendChild(card);
            });
        }

        // ============================================================
        // 6. OUVERTURE D'UN EXAMEN
        // ============================================================
        function openExamen(examId) {
            // Si un examen est déjà ouvert, on arrête le timer
            if (timerInterval) {
                clearInterval(timerInterval);
                timerInterval = null;
            }

            const exam = examensData.find(e => e.id === examId);
            if (!exam) return;

            currentExamId = examId;
            examenTitre.textContent = `${exam.emoji} ${exam.titre}`;

            // Réinitialiser le timer
            timeLeft = 3600;
            timerDisplay.textContent = `⏱️ 60:00`;
            timerDisplay.classList.remove('warning');
            examStarted = false;

            // Construire le corps de l'examen
            let html = '';
            exam.questions.forEach((q, idx) => {
                html += `<div class="question"><div class="q">${q.q}</div>`;
                if (q.type === 'radio') {
                    html += `<div class="options">`;
                    q.options.forEach(opt => {
                        html += `<label><input type="radio" name="q${idx}" value="${opt}" /> ${opt}</label>`;
                    });
                    html += `</div>`;
                } else if (q.type === 'text') {
                    html += `<input type="text" placeholder="${q.placeholder || 'Votre réponse...'}" style="max-width:100%;" />`;
                }
                html += `</div>`;
            });
            examenBody.innerHTML = html;

            // Afficher la vue examen, cacher le dashboard
            document.getElementById('dashboard').style.display = 'none';
            examenView.classList.add('active');

            // Démarrer le timer
            examStarted = true;
            timerInterval = setInterval(() => {
                timeLeft--;
                timerDisplay.textContent = `⏱️ ${formatTime(timeLeft)}`;
                if (timeLeft <= 60) timerDisplay.classList.add('warning');
                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    timerInterval = null;
                    timerDisplay.textContent = '⏱️ 00:00';
                    showToast('⏰ Temps écoulé ! L\'examen est automatiquement soumis.');
                    // On peut ajouter un comportement de soumission auto ici si voulu
                    // Pour l'instant on bloque la soumission manuelle
                    btnSubmit.disabled = true;
                    btnSubmit.textContent = '⏳ Terminé';
                }
            }, 1000);
        }

        // ============================================================
        // 7. RETOUR AU TABLEAU DE BORD
        // ============================================================
        function goBack() {
            if (timerInterval) {
                clearInterval(timerInterval);
                timerInterval = null;
            }
            examenView.classList.remove('active');
            document.getElementById('dashboard').style.display = 'block';
            // Réinitialiser le bouton submit
            btnSubmit.disabled = false;
            btnSubmit.textContent = '📤 Soumettre';
            currentExamId = null;
            showToast('📋 Retour au tableau de bord');
        }

        btnBack.addEventListener('click', goBack);

        // ============================================================
        // 8. SOUMISSION (simulation)
        // ============================================================
        btnSubmit.addEventListener('click', () => {
            if (btnSubmit.disabled) {
                showToast('⏳ Le temps est écoulé.');
                return;
            }
            // Récupérer les réponses
            const exam = examensData.find(e => e.id === currentExamId);
            if (!exam) return;
            const inputs = examenBody.querySelectorAll('input');
            let reponses = [];
            inputs.forEach((inp, idx) => {
                if (inp.type === 'radio' && inp.checked) {
                    reponses.push(`Q${idx+1}: ${inp.value}`);
                } else if (inp.type === 'text' && inp.value.trim()) {
                    reponses.push(`Q${idx+1}: ${inp.value.trim()}`);
                }
            });
            // Arrêter le timer
            if (timerInterval) {
                clearInterval(timerInterval);
                timerInterval = null;
            }
            showToast(`✅ Examen soumis ! (${reponses.length} réponses enregistrées)`);
            // Désactiver la soumission
            btnSubmit.disabled = true;
            btnSubmit.textContent = '✅ Soumis';
            // On pourrait enregistrer les réponses dans la console / localStorage
            console.log('Réponses soumises :', reponses);
            // Option : afficher un récapitulatif
            alert(`Examen "${exam.titre}" soumis avec succès.\n\nRéponses fournies :\n${reponses.join('\n') || 'Aucune réponse enregistrée.'}`);
        });

        // ============================================================
        // 9. DÉMARRAGE (si déjà connecté, on affiche le dashboard)
        // ============================================================
        // Par défaut, l'overlay est visible, le main caché.
        // Si on veut skipper le login pour le test, on décommente :
        // loginOverlay.classList.add('hidden');
        // mainContainer.style.display = 'block';
        // currentUser = { nom: 'Test', prenom: 'Élève' };
        // userDisplay.textContent = 'Élève Test';
        // renderGrille();

        console.log('📚 Complexe Éducatif Jean Jacques Dessalines – Examens 6e AF');
        console.log('💡 Contact: +509 3391 0384');
    </script>

